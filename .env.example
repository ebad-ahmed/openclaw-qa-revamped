# ─────────────────────────────────────────────────────────────────────────────
# OpenClaw QA — Environment Variables
#
# Copy this file to .env and fill in the values for your deployment.
#   cp .env.example .env
#
# NEVER commit .env — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core URLs ─────────────────────────────────────────────────────────────────

# Base URL of the OpenClaw web UI (the address you open in a browser)
OPENCLAW_BASE_URL=http://localhost:18789

# Direct URL of the OpenClaw API gateway (used for /healthz and /status checks)
# Usually the same host/port as OPENCLAW_BASE_URL
OPENCLAW_GATEWAY_URL=http://localhost:18789

# ── Authentication ────────────────────────────────────────────────────────────

# Gateway token used to log in.
# OpenClaw uses a single-token auth model (no email + password).
# Copy the token from your OpenClaw admin panel or .env on the server.
TEST_AUTH_TOKEN=your-gateway-token-here

# ── Skills ────────────────────────────────────────────────────────────────────

# Comma-separated list of skill names that MUST be installed and enabled.
# Tests in skills.spec.ts will fail if any of these are missing.
# Example: browser,web-search,code-interpreter,file-manager
SKILLS_TO_VERIFY=browser,web-search

# ── Live / Canary Tests ───────────────────────────────────────────────────────

# Set to 1 to enable tests that call the real AI model.
# Leave unset (or 0) for quick smoke/unit runs that don't need a live model.
OPENCLAW_LIVE_TEST=0

# Model identifier used by the live tests (informational — captured in failure artifacts)
OPENCLAW_LIVE_MODEL=anthropic/claude-sonnet-4-6

# ── Canary Alerting ───────────────────────────────────────────────────────────

# Slack or Discord webhook URL.
# If set, scripts/canary-alert.js posts an alert when canary tests fail.
# Leave blank to disable alerting (failures will still appear in test output).
ALERT_WEBHOOK_URL=
