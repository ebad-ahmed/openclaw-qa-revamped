# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
package-lock.json        # regenerated by npm install; not committed

# ── Environment / Secrets ─────────────────────────────────────────────────────
# NEVER commit real credentials.  Use .env.example as the template.
.env
.env.local
.env.*.local

# ── Playwright output ─────────────────────────────────────────────────────────
test-results/            # raw playwright artefacts (screenshots, videos, traces)
reports/                 # generated HTML / JSON reports
playwright-report/

# ── Debug helpers (used during development, not needed in repo) ───────────────
dump-skills-html.js
dump-skills.js

# ── Editor / OS ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# ── Legacy Play! framework ignores (kept for safety) ─────────────────────────
bin/
/db
.eclipse
/lib/
/logs/
/modules
/project/project
/project/target
/target
tmp/
test-result
server.pid
*.eml
/dist/
.cache
